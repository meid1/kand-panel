# ── Kand — пример конфигурации. Скопируй в .env и заполни секреты. ──
# БД и кэш
DATABASE_URL=postgresql://kand:kand@localhost:5432/kand
REDIS_URL=redis://localhost:6379

# API
API_PORT=3000
# Публичный адрес панели (для ссылок подписки и команды установки нод). БЕЗ слэша на конце.
PANEL_URL=https://panel.example.com
# CORS: список доменов через запятую (пусто = запрещено)
CORS_ORIGIN=

# Безопасность (ОБЯЗАТЕЛЬНО смени оба!)
ADMIN_PASSWORD=changeme
JWT_SECRET=change_me_to_a_long_random_string

# Клиентский Telegram-бот (опционально; можно задать и в настройках bot.token)
BOT_TOKEN=

# Путь к корню репозитория (для раздачи install-node.sh и бинаря агента)
VPANEL_ROOT=/opt/kand
