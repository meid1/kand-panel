{
  "name": "kand",
  "private": true,
  "version": "0.0.1",
  "description": "Open-source VPN management panel (xray/VLESS/Hysteria2) with smart RU-direct routing, ad-free YouTube, franchises & self-service. AGPLv3.",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev:db": "docker compose -f infra/docker-compose.dev.yml up -d",
    "prisma:generate": "prisma generate --schema packages/db/prisma/schema.prisma",
    "prisma:push": "prisma db push --schema packages/db/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema packages/db/prisma/schema.prisma"
  },
  "license": "AGPL-3.0-only"
}
