// Kand — схема БД (PostgreSQL). Мультитенант + умная маршрутизация и метринг обхода.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Тенант = платформа-владелец ИЛИ франшиза (мультитенант, изоляция клиентов).
model Tenant {
  id            String   @id @default(cuid())
  kind          String   @default("franchise") // "platform" | "franchise"
  brand         String   @default("VPN")
  brandColor    String?
  ownerTgId     BigInt?
  botToken      String?  // токен Telegram-бота франшизы
  botUsername   String?
  domain        String?  @unique // кастом-домен (авто-HTTPS)
  domainVerified Boolean @default(false)
  sharePercent  Int      @default(50)   // доля франшизы
  balance       Decimal  @default(0)
  pricePerMonth Decimal  @default(90)
  welcomeText   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  users         User[]
  nodes         Node[]   // BYON-ноды франшизы (изоляция)
  payments      Payment[]
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  tgId         BigInt
  externalId   String?  // id исходной системы при импорте (напр. "cat_12345") — для дедупа/маппинга
  tgUsername   String?
  tgName       String?
  referralCode String?  @unique // личный код-приглашение (для реф-ссылки)
  referrerId   String?  // кто пригласил (User.id того же тенанта)
  refEarnedDays Int     @default(0) // сколько дней заработано на рефералах
  refFirstPay  Boolean  @default(false) // была ли уже первая оплата (чтобы наградить пригласившего 1 раз)
  agreedTerms  Boolean  @default(false) // согласие с условиями/офертой
  remindStage  Int      @default(0) // напоминания об истечении: 0=нет,1=за3д,2=за1д,3=истекло
  expireAt     DateTime?
  isTrial      Boolean  @default(true)
  trialUsed    Boolean  @default(false)
  isBlocked    Boolean  @default(false)
  autoRenew    Boolean  @default(false)
  autoRenewPlanId String? // какой тариф списывать с баланса при автопродлении
  balance      Decimal  @default(0)
  promoGroupId String?  // сегмент со скидкой (PromoGroup)
  promoGroup   PromoGroup? @relation(fields: [promoGroupId], references: [id])
  campaignId   String?  // UTM-кампания, приведшая клиента
  campaign     Campaign? @relation(fields: [campaignId], references: [id])
  createdAt    DateTime @default(now())
  devices      Device[]
  payments     Payment[]
  bypass       BypassUsage?
  tickets      Ticket[]
  savedCards   SavedCard[]
  @@unique([tenantId, tgId]) // Phase 0 изоляция: (тенант, tg) = 1 аккаунт
  @@index([tenantId, externalId]) // дедуп при импорте по исходному id
  @@index([promoGroupId])
  @@index([campaignId])
}

/// Промо-группа: сегмент клиентов с фиксированной скидкой (%) на оплату/продление.
model PromoGroup {
  id          String   @id @default(cuid())
  tenantId    String?
  name        String
  discountPct Int      @default(0) // 0..100
  createdAt   DateTime @default(now())
  users       User[]
}

/// Сохранённая карта для рекуррента (автосписание). methodId — токен карты у провайдера.
model SavedCard {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  provider  String   // yookassa
  methodId  String   // payment_method_id у провайдера
  title     String?  // маскированная карта (напр. •• 1234)
  createdAt DateTime @default(now())
  @@index([userId])
}

/// UTM-кампания: трекинг воронки переход(клик)→регистрация→оплата по метке.
model Campaign {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String
  code      String   @unique // метка в ссылке /c/<code> и в ?start=c_<code>
  clicks    Int      @default(0)
  createdAt DateTime @default(now())
  users     User[]
}

/// Тикеты поддержки: обращения клиента (из бота/кабинета) и ответы админа.
model Ticket {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  subject   String
  status    String   @default("open") // open | answered | closed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  TicketMessage[]
  @@index([tenantId, status, updatedAt])
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fromAdmin Boolean  @default(false)
  text      String
  createdAt DateTime @default(now())
  @@index([ticketId, createdAt])
}

/// Подарочные подписки: код покупает один, активирует другой.
model GiftCode {
  id         String    @id @default(cuid())
  tenantId   String?
  code       String    @unique
  days       Int
  buyerId    String?   // кто купил (User.id)
  redeemedBy String?   // кто активировал (User.id)
  redeemedAt DateTime?
  createdAt  DateTime  @default(now())
}

/// Устройство = один VLESS-uuid, отдаётся в подписке.
model Device {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  name       String   @default("Устройство")
  vlessUuid  String   @unique
  subToken   String   @unique
  tvCode     String?  @unique // короткий код для ТВ (легко ввести пультом): PANEL/t/<code>
  createdAt  DateTime @default(now())
  keySync    KeySyncStatus[]
}

/// Нода = Docker-контейнер с xray. Провижн через mTLS+JWT (без SSH).
model Node {
  id           String   @id @default(cuid())
  tenantId     String?  // null = общий пул платформы; иначе BYON франшизы
  tenant       Tenant?  @relation(fields: [tenantId], references: [id])
  label        String
  address      String   // хост/IP для клиентских ссылок
  ip           String
  secretKey    String   // base64(nodeCert+nodeKey+caCert+jwtPubkey) для mTLS
  port         Int      @default(443)
  protocols    String[] // reality-tcp, reality-grpc, hysteria2, xhttp
  sni          String?
  realityPbk   String?
  realitySid   String?
  isActive     Boolean  @default(true)
  showInSub    Boolean  @default(true)
  sortOrder    Int      @default(0)
  role         String   @default("exit") // exit | bypass-origin | yt-ru | warp
  warpKey      String?  // приватный WG-ключ WARP (чистый IP для нейросетей); null = WARP выкл
  trafficLimitGb Int?
  online       Boolean  @default(false)
  lastCheck    DateTime?
  keySync      KeySyncStatus[]
  inbounds     Inbound[]
  createdAt    DateTime @default(now())
}

model Inbound {
  id        String  @id @default(cuid())
  nodeId    String
  node      Node    @relation(fields: [nodeId], references: [id])
  tag       String
  protocol  String
  network   String  // tcp | grpc | xhttp | hysteria
  port      Int
}

model KeySyncStatus {
  id         String   @id @default(cuid())
  deviceId   String
  device     Device   @relation(fields: [deviceId], references: [id])
  nodeId     String
  node       Node     @relation(fields: [nodeId], references: [id])
  synced     Boolean  @default(false)
  lastAttempt DateTime?
  lastError  String?
  @@unique([deviceId, nodeId])
}

model Payment {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  amount     Decimal
  method     String   // provider id: yookassa|cryptobot|cryptomus|lava|... (реестр)
  status     String   @default("pending") // pending|paid|failed|refunded
  invoiceId  String?  // внешний id платежа у провайдера
  days       Int?     // сколько дней подписки начислить при успешной оплате
  topup      Boolean  @default(false) // пополнение баланса (а не покупка подписки)
  description String?
  createdAt  DateTime @default(now())
  paidAt     DateTime?
  @@index([tenantId, status])
}

/// Метринг обхода (ОБХОД БС): лимит ГБ per-user, докупка, подарки.
model BypassUsage {
  userId        String   @id
  user          User     @relation(fields: [userId], references: [id])
  totalBytes    BigInt   @default(0)
  baselineBytes BigInt   @default(0)
  purchasedBytes BigInt  @default(0)
  giftBytes     BigInt   @default(0)
  giftUntil     DateTime?
  capGb         Int?     // тарифный лимит
  capManualGb   Int?     // ручной admin-лимит (перебивает)
  isSuspended   Boolean  @default(false)
  periodStart   DateTime @default(now())
}

model PromoCode {
  id        String   @id @default(cuid())
  code      String   @unique
  type      String   // days | bypass_gb | balance
  value     Float
  maxUses   Int      @default(1)
  usedCount Int      @default(0)
  createdAt DateTime @default(now())
}

/// HWID-устройство клиента (аппаратный id из приложения) — для лимита устройств.
model UserHwid {
  id       String   @id @default(cuid())
  userId   String
  hwid     String
  os       String?
  model    String?
  lastSeen DateTime @default(now())
  createdAt DateTime @default(now())
  @@unique([userId, hwid])
  @@index([userId])
}

/// Погашение промокода клиентом (защита от повторного использования одним юзером).
model PromoRedemption {
  id          String   @id @default(cuid())
  promoCodeId String
  userId      String
  createdAt   DateTime @default(now())
  @@unique([promoCodeId, userId])
}

/// Тариф (несколько на выбор: 1/3/6/12 мес, число устройств, цена).
model Plan {
  id          String  @id @default(cuid())
  tenantId    String? // null = платформенный; иначе тариф франшизы
  title       String  // «1 месяц», «Год» …
  days        Int
  price       Decimal
  deviceLimit Int     @default(0) // 0 = без ограничения
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
}

/// Глобальные настройки платформы (флаги, маршрутизация, цены).
model Setting {
  key   String @id
  value String
}

/// Аудит действий в админке (кто что менял) — на случай компрометации.
model AuditLog {
  id        String   @id @default(cuid())
  actor     String   // "admin" (или id пользователя в будущем)
  action    String   // "POST /nodes", "DELETE /users/:id" …
  target    String?  // id объекта
  ip        String?
  meta      String?  // краткий JSON тела запроса БЕЗ секретов
  createdAt DateTime @default(now())
  @@index([createdAt])
}

/// Ручной учёт финансов: расходы (сервера, реклама) и внешние доходы — поверх
/// автоматических платежей. Для раздела «Финансы» (доход − расход = прибыль).
model LedgerEntry {
  id        String   @id @default(cuid())
  tenantId  String?  // null = платформа; иначе франшиза
  kind      String   // "expense" | "income"
  amount    Decimal
  note      String?
  createdAt DateTime @default(now())
  @@index([tenantId, kind, createdAt])
}
